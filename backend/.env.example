NODE_ENV=development
PORT=5000
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free
CLIENT_URL=http://localhost:3000
SCREENSHOTS_DIR=./screenshots
REPORTS_DIR=./reports
MAX_SCAN_DEPTH=3
SCAN_TIMEOUT=30000

# Shared access code required (via X-Demo-Code header) to use the scan,
# bounty, or report routes. Without this set, those routes reject every
# request — prevents anonymous visitors from running the active scanner
# or burning your AI key.
DEMO_ACCESS_CODE=
